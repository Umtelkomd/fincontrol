rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Deny all by default
    match /{document=**} {
      allow read, write: if false;
    }

    // ─────────────────────────────────────────────
    // User registry: stores role + appId per user
    // Bootstrap: run scripts/bootstrap-users.js after
    // deploying these rules for the first time.
    // ─────────────────────────────────────────────
    match /users/{userId} {
      allow read: if request.auth != null
        && request.auth.uid == userId;

      // Self-create: only permitted with non-privileged role.
      // The app never writes users/{uid} from the client (bootstrap uses Admin SDK),
      // but this rule prevents anyone from self-assigning role:'admin' or 'manager'.
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'editor';

      // Self-update: user may update their own doc ONLY if role and appId are unchanged.
      // Admins may update any user document without restriction.
      allow update: if request.auth != null
        && (
          (
            request.auth.uid == userId
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['role', 'appId'])
          )
          || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
        );
    }

    // ─────────────────────────────────────────────
    // payrollPeriods — holds per-employee salary lines.
    // Firestore rule grants are OR-unioned: a broad grant CANNOT be tightened
    // by a more-specific match. So this dedicated block restricts read to
    // manager/admin, AND the generic data block below explicitly EXCLUDES
    // payrollPeriods from its read grant (otherwise editors would still read it).
    // Functions are redeclared locally because rules functions are block-scoped.
    // ─────────────────────────────────────────────
    match /artifacts/{appId}/public/data/payrollPeriods/{document=**} {
      function pUserRole() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }
      function pOwnTenant() {
        return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appId == appId;
      }
      function pManagerOrAbove() {
        return request.auth != null && (pUserRole() == 'admin' || pUserRole() == 'manager');
      }
      allow read: if request.auth != null && pOwnTenant() && pManagerOrAbove();
      allow write: if request.auth != null && pOwnTenant() && pManagerOrAbove();
    }

    // ─────────────────────────────────────────────
    // employees — holds IBAN/BIC and per-employee salary data (brutto/netto/
    // gesamtkosten). Same confinement pattern as payrollPeriods: dedicated
    // manager/admin-only block here, plus an explicit exclusion in the generic
    // read grant below (grants are OR-unioned, so the exclusion is what
    // actually keeps editors out).
    // ─────────────────────────────────────────────
    match /artifacts/{appId}/public/data/employees/{document=**} {
      function eUserRole() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }
      function eOwnTenant() {
        return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appId == appId;
      }
      function eManagerOrAbove() {
        return request.auth != null && (eUserRole() == 'admin' || eUserRole() == 'manager');
      }
      allow read: if request.auth != null && eOwnTenant() && eManagerOrAbove();
      allow write: if request.auth != null && eOwnTenant() && eManagerOrAbove();
    }

    // ─────────────────────────────────────────────
    // Tenant-scoped FinControl data
    // appId acts as tenant key for multi-app isolation
    // ─────────────────────────────────────────────
    match /artifacts/{appId}/public/data/{collection}/{document=**} {
      // Helper: fetch current user's role from Firestore
      function userRole() {
        return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
      }

      function isOwnTenant() {
        return request.auth != null
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.appId == appId;
      }

      // Read: any authenticated tenant user — EXCEPT payrollPeriods and
      // employees, which are confined to manager/admin by their own dedicated
      // match blocks above (grants are OR-unioned, so these exclusions are
      // what actually restrict editors).
      allow read: if request.auth != null && isOwnTenant()
        && collection != 'payrollPeriods'
        && collection != 'employees';

      // Write: admins and managers of this tenant
      function isManagerOrAbove() {
        return request.auth != null && (userRole() == 'admin' || userRole() == 'manager');
      }
      allow write: if request.auth != null && isManagerOrAbove() && isOwnTenant();
    }
  }
}
